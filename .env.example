# ==============================================================================
# PDF EXTRACTOR RAG SYSTEM - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and configure your settings

# ==============================================================================
# EMBEDDING PROVIDER CONFIGURATION
# ==============================================================================
# Options: "local", "google"
# - local: Uses sentence-transformers (FREE, no API key needed, runs locally)
# - google: Uses Google Gemini embeddings (requires GOOGLE_API_KEY)
EMBEDDING_PROVIDER=local

# ==============================================================================
# LOCAL EMBEDDING MODELS (when EMBEDDING_PROVIDER=local)
# ==============================================================================
# Popular options:
# - all-MiniLM-L6-v2 (384 dim) - FAST, good quality, RECOMMENDED for most use cases
# - all-mpnet-base-v2 (768 dim) - Better quality but slower
# - paraphrase-multilingual-MiniLM-L12-v2 (384 dim) - For multilingual documents
# - all-MiniLM-L12-v2 (384 dim) - Balance of speed and quality
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==============================================================================
# LLM PROVIDER CONFIGURATION
# ==============================================================================
# Options: "groq", "openai", "ollama"
# - groq: Fast inference with Groq (requires GROQ_API_KEY) - RECOMMENDED
# - openai: OpenAI models (requires OPENAI_API_KEY)
# - ollama: Local LLM via Ollama (free, no API key)
LLM_PROVIDER=groq

# ==============================================================================
# LLM MODEL SELECTION
# ==============================================================================
# For Groq (fast and cheap):
# - llama-3.3-70b-versatile (RECOMMENDED)
# - llama-3.1-70b-versatile
# - mixtral-8x7b-32768
# - gemma-7b-it
LLM_MODEL_NAME=llama-3.3-70b-versatile

# ==============================================================================
# API KEYS
# ==============================================================================
# GROQ API KEY (for LLM - FREE tier available)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# GOOGLE API KEY (only needed if EMBEDDING_PROVIDER=google)
# Get it from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OPENAI API KEY (only needed if LLM_PROVIDER=openai)
# Get it from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# ==============================================================================
# REDIS CONFIGURATION (Optional - for caching)
# ==============================================================================
# Leave commented out if not using Redis
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ==============================================================================
# DOCUMENT PROCESSING CONFIGURATION
# ==============================================================================
# Chunk size for text splitting (characters)
# CHUNK_SIZE=1000

# Chunk overlap for context preservation
# CHUNK_OVERLAP=200

# ==============================================================================
# RETRIEVAL CONFIGURATION
# ==============================================================================
# Number of chunks to retrieve for each query
# TOP_K_RETRIEVAL=10

# Minimum similarity score threshold (0.0 to 1.0)
# SIMILARITY_THRESHOLD=0.3

# ==============================================================================
# RECOMMENDED CONFIGURATIONS
# ==============================================================================

# OPTION 1: Completely FREE (No API keys needed)
# ----------------------------------------
# EMBEDDING_PROVIDER=local
# LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
# LLM_PROVIDER=ollama
# LLM_MODEL_NAME=llama3
# (Note: Requires Ollama installed locally)

# OPTION 2: Best Quality + Speed (Free Groq API)
# ----------------------------------------
# EMBEDDING_PROVIDER=local
# LOCAL_EMBEDDING_MODEL=all-mpnet-base-v2
# LLM_PROVIDER=groq
# LLM_MODEL_NAME=llama-3.3-70b-versatile
# GROQ_API_KEY=<your_key>

# OPTION 3: Google Gemini (Requires Google API key)
# ----------------------------------------
# EMBEDDING_PROVIDER=google
# LLM_PROVIDER=groq
# LLM_MODEL_NAME=llama-3.3-70b-versatile
# GOOGLE_API_KEY=<your_key>
# GROQ_API_KEY=<your_key>

# ==============================================================================
# NOTES
# ==============================================================================
# 1. The "local" embedding provider is RECOMMENDED as it's:
#    - Completely FREE
#    - Fast (runs on your machine)
#    - No API limits
#    - Privacy-friendly (no data sent to external services)
#
# 2. Groq provides fast, high-quality LLM inference with a generous free tier
#
# 3. For production, consider using Redis caching to speed up repeated queries
#
# 4. All settings have sensible defaults, only API keys are required
# ==============================================================================
